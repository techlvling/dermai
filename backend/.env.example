# OpenRouter API key — get yours free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Groq API key (fallback when OpenRouter is rate-limited) — get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Port (optional, defaults to 3000)
PORT=3000

# Allowed CORS origins — comma-separated; add Vercel preview URLs here
# Defaults to localhost:3000 + dermai-livid.vercel.app when unset
# ALLOWED_ORIGINS=http://localhost:3000,https://dermai-livid.vercel.app,https://dermai-abc123-techlvling.vercel.app

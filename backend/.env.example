# Google AI Studio API key (PRIMARY AI provider) — get yours at https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=your_aistudio_key_here

# OpenRouter API key (FALLBACK AI provider) — get yours free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Port (optional, defaults to 3000)
PORT=3000

# Admin panel access — comma-separated list of Google account emails
ADMIN_EMAILS=your_admin@gmail.com

# Cron job secret — used by Vercel's weekly cron to call /api/cron/refresh-evidence
# CRON_SECRET=your_cron_secret_here

# Allowed CORS origins — comma-separated; add Vercel preview URLs here
# Defaults to localhost:3000 + tinkskin.in (+ www) + the legacy vercel URL when unset
# ALLOWED_ORIGINS=http://localhost:3000,https://tinkskin.in,https://www.tinkskin.in,https://tinkskin-abc123-techlvling.vercel.app
